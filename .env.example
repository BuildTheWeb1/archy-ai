# Copy this file to .env and fill in your values
# The backend reads these automatically when you start it

# Anthropic API key — used for AI vision extraction of rebar schedules
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Autodesk Platform Services credentials — used for DWG/DXF → PDF conversion
# Create an app at https://aps.autodesk.com/myapps
APS_CLIENT_ID=your-aps-client-id
APS_CLIENT_SECRET=your-aps-client-secret
